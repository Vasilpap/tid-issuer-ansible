---
# Copy to group_vars/secrets.yml and encrypt with Ansible Vault:
#   cp group_vars/secrets.yml.example group_vars/secrets.yml
#   ansible-vault encrypt group_vars/secrets.yml

# API host secrets
vault_tid_api_db_password: "replace-me"
vault_tid_api_oidc_credentials_secret: ""
vault_tid_api_minio_access_key: "replace-me"
vault_tid_api_minio_secret_key: "replace-me"

# Infra host secrets
vault_tid_platform_quarkus_db_password: "replace-me"
vault_tid_platform_keycloak_db_password: "replace-me"
vault_tid_platform_kc_admin_password: "replace-me"
vault_tid_platform_minio_root_password: "replace-me"

# docker-env host secrets
vault_tid_docker_env_quarkus_db_password: "replace-me"
vault_tid_docker_env_keycloak_db_password: "replace-me"
vault_tid_docker_env_kc_admin_password: "replace-me"
vault_tid_docker_env_minio_root_password: "replace-me"
vault_tid_docker_env_api_oidc_credentials_secret: ""

# Optional GHCR credentials (not needed for public images)
vault_tid_docker_env_ghcr_username: ""
vault_tid_docker_env_ghcr_token: ""
